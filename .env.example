# Copy to .env and fill in to switch from offline backends to production ones.

# --- backends ---
STORM_EMBEDDING_BACKEND=local        # local | openai | sentence-transformers
STORM_LLM_BACKEND=mock-grounded      # mock-grounded | mock-naive | openai | ollama
STORM_VECTORSTORE_BACKEND=local      # local | chroma | pinecone

# --- OpenAI ---
OPENAI_API_KEY=
STORM_OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434

# --- MLflow ---
MLFLOW_TRACKING_URI=data/mlruns
STORM_EXPERIMENT=storm-eval

# --- Databricks (production pipelines) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=
