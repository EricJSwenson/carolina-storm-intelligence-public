FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn pydantic numpy scipy duckdb jinja2 pyyaml
COPY src/ ./src/
COPY conf/ ./conf/
COPY data/ ./data/
ENV PYTHONPATH=/app/src
EXPOSE 8000
CMD ["uvicorn", "storm_eval.serving.api:app", "--host", "0.0.0.0", "--port", "8000"]
